# Supabase — rasi: supabase.com → Project Settings → API
# Kopijuok šį failą į .env.local ir užpildyk savo reikšmes

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# APP URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# DĖMESIO: service_role key NIEKADA nedėti į šį failą!
# Jis naudojamas tik server-side, tiesiai Supabase Dashboard'e.
